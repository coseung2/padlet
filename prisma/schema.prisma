// Padlet clone — Prisma schema
// DB: SQLite for local dev. To switch to Postgres:
//   1) change provider to "postgresql"
//   2) change DATABASE_URL to postgres://…
//   3) run `prisma db push --force-reset`
// Avoid SQLite-specific types (@db.*) so the schema stays portable.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())

  memberships  BoardMember[]
  cards        Card[]
  submissions  Submission[]
  accounts     Account[]
  sessions     Session[]
  classrooms   Classroom[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ──── Classroom system ────

model Classroom {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique   // 6-char alphanumeric, teacher shares this
  teacherId String
  createdAt DateTime @default(now())

  teacher   User      @relation(fields: [teacherId], references: [id])
  students  Student[]
  boards    Board[]   @relation("ClassroomBoards")

  @@index([teacherId])
  @@index([code])
}

model Student {
  id          String   @id @default(cuid())
  classroomId String
  name        String
  qrToken     String   @unique   // UUID — encoded in QR
  textCode    String   @unique   // 6-char alphanumeric — manual entry fallback
  sessionVersion Int   @default(1)
  createdAt   DateTime @default(now())

  classroom   Classroom    @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  quizPlayers QuizPlayer[]

  @@index([classroomId])
  @@index([qrToken])
  @@index([textCode])
}

// layout: "freeform" | "grid" | "stream" | "columns"
// (columns prep for next task; validated in app via zod)
model Board {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  layout      String   @default("freeform")
  description String   @default("")
  classroomId String?
  createdAt   DateTime @default(now())

  classroom   Classroom? @relation("ClassroomBoards", fields: [classroomId], references: [id], onDelete: SetNull)
  members     BoardMember[]
  cards       Card[]
  sections    Section[]
  submissions Submission[]
  quizzes     Quiz[]
}

// Columns/Kanban용 섹션 (grid/stream에선 사용 안 함)
model Section {
  id      String @id @default(cuid())
  boardId String
  title   String
  order   Int    @default(0)

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[] @relation("SectionCards")

  @@index([boardId])
}

// RBAC core: one row per (board, user).
// role: "owner" | "editor" | "viewer" (validated in app via zod)
model BoardMember {
  id      String @id @default(cuid())
  boardId String
  userId  String
  role    String

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([userId])
}

model Card {
  id        String   @id @default(cuid())
  boardId   String
  sectionId String?
  authorId  String
  title     String
  content   String
  color     String?
  imageUrl  String?
  linkUrl   String?
  linkTitle String?
  linkDesc  String?
  linkImage String?
  videoUrl  String?
  x         Float    @default(0)
  y         Float    @default(0)
  width     Float    @default(240)
  height    Float    @default(160)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board   Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  section Section? @relation("SectionCards", fields: [sectionId], references: [id], onDelete: SetNull)
  author  User     @relation(fields: [authorId], references: [id])

  @@index([boardId])
  @@index([sectionId])
}

model Submission {
  id        String   @id @default(cuid())
  boardId   String
  userId    String
  content   String   @default("")
  linkUrl   String?
  fileUrl   String?
  status    String   @default("submitted") // "submitted" | "reviewed" | "returned"
  feedback  String?
  grade     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([boardId, userId])
  @@index([boardId])
  @@index([userId])
}

// ──── Quiz system ────

model Quiz {
  id          String   @id @default(cuid())
  boardId     String
  title       String   @default("")
  sourceFile  String?  // uploaded PDF/PPT filename
  sourceText  String?  // extracted text (for reference)
  roomCode    String   @unique // 6-digit code for students to join
  status      String   @default("waiting") // "waiting" | "active" | "finished"
  currentQ    Int      @default(-1) // index of current question (-1 = not started)
  createdAt   DateTime @default(now())

  board     Board          @relation(fields: [boardId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  players   QuizPlayer[]

  @@index([boardId])
  @@index([roomCode])
}

model QuizQuestion {
  id       String @id @default(cuid())
  quizId   String
  order    Int    @default(0)
  question String
  optionA  String
  optionB  String
  optionC  String
  optionD  String
  answer   String // "A" | "B" | "C" | "D"
  timeLimit Int   @default(20) // seconds

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([quizId])
}

model QuizPlayer {
  id        String   @id @default(cuid())
  quizId    String
  studentId String?
  nickname  String
  score     Int      @default(0)
  joinedAt  DateTime @default(now())

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student Student?     @relation(fields: [studentId], references: [id])
  answers QuizAnswer[]

  @@unique([quizId, studentId])
  @@index([quizId])
  @@index([studentId])
}

model QuizAnswer {
  id         String   @id @default(cuid())
  questionId String
  playerId   String
  selected   String   // "A" | "B" | "C" | "D"
  correct    Boolean
  timeMs     Int      @default(0) // answer time in ms
  createdAt  DateTime @default(now())

  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  player   QuizPlayer   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([questionId, playerId])
  @@index([questionId])
  @@index([playerId])
}
