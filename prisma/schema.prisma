// Aura-board — Prisma schema
// DB: SQLite for local dev. To switch to Postgres:
//   1) change provider to "postgresql"
//   2) change DATABASE_URL to postgres://…
//   3) run `prisma db push --force-reset`
// Avoid SQLite-specific types (@db.*) so the schema stays portable.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())

  memberships            BoardMember[]
  cards                  Card[]
  submissions            Submission[]
  reviews                SubmissionReview[]
  accounts               Account[]
  sessions               Session[]
  classrooms             Classroom[]
  templatesOwned         BreakoutTemplate[]        @relation("TemplateOwner")
  issuedParentInvites    ParentInviteCode[]        @relation("TeacherInvite")
  canvaConnect           CanvaConnectAccount?
  // parent-class-invite-v2 — issued codes + audit FKs into ParentChildLink
  classInvitesIssued     ClassInviteCode[]         @relation("ClassInviteIssued")
  approvedParentLinks    ParentChildLink[]         @relation("LinkApprovedBy")
  rejectedParentLinks    ParentChildLink[]         @relation("LinkRejectedBy")
  revokedParentLinks     ParentChildLink[]         @relation("LinkRevokedBy")
  // dj-board-queue — teacher audit for role assignments
  roleAssignmentsGranted ClassroomRoleAssignment[] @relation("ClassroomRoleAssignedBy")
  // Teacher's own LLM API key (vibe-arcade + future AI features)
  llmKey                 TeacherLlmKey?
  // Billing (Toss Payments 정기결제 — Seed 14 scaffold, 2026-04-22)
  subscription           TeacherSubscription?
  paymentEvents          PaymentEvent[]
  boardResponses         BoardResponse[]           @relation("UserBoardResponses")
  // AI 평어 (2026-04-24) — 교사가 학생별로 생성한 평어 텍스트
  aiFeedbacks            AiFeedback[]              @relation("TeacherAiFeedbacks")
  // OAuth as subject — Aura companion teacher OAuth (2026-04-24)
  oauthAuthCodesAsUser   OAuthAuthCode[]           @relation("UserOAuthAuthCodes")
  oauthAccessTokensAsUser  OAuthAccessToken[]      @relation("UserOAuthAccessTokens")
  oauthRefreshTokensAsUser OAuthRefreshToken[]     @relation("UserOAuthRefreshTokens")
}

// ──── Audit Log (Seed 14 security, 2026-04-22) ────
// 권한 있는 행동(역할 부여, 보드 삭제, 환불, 웹훅 처리, 토큰 회전 등)의
// 감사 추적. `actorType` + `actorId` 로 교사/학생/시스템/관리자 구분.
// `metadata` JSON 에 이전 상태·결과 등 상세 컨텍스트. `resourceType/Id` 로
// 대상 식별. 사고 발생 시 createdAt 범위로 타임라인 재구성.
model AuditEvent {
  id           String   @id @default(cuid())
  actorType    String // "teacher" | "student" | "system" | "admin"
  actorId      String? // nullable (system actions)
  action       String // "board.delete" | "role.grant" | "billing.refund" | "admin.rotate_tokens" | ...
  resourceType String? // "board" | "classroom" | "student" | "subscription" | ...
  resourceId   String?
  metadata     Json?
  ip           String? // extractIp + hashIp 결과 (16자 sha256 prefix)
  createdAt    DateTime @default(now())

  @@index([actorType, actorId, createdAt])
  @@index([action, createdAt])
  @@index([resourceType, resourceId])
}

// ──── Teacher LLM API Key (Seed 13 follow-up, 2026-04-22) ────
// 교사가 /docs/ai-setup 페이지에서 입력한 Claude/OpenAI/Gemini API Key.
// 서버 AES-256-GCM 암호화 후 DB 저장. 학생 클라이언트에는 절대 내려가지 않고
// 모든 호출은 서버 프록시(/api/vibe/sessions)에서 복호화 → 각 사 API로 포워딩.
//
// 1 teacher = 1 key row (재저장 시 upsert로 덮어쓰기).
// verified/verifiedAt: 저장 시 각 사 API에 작은 테스트 호출을 보내 성공했는지.
// lastError: 401/결제 실패 등을 UI에 표시하기 위한 최근 에러 메시지.
model TeacherLlmKey {
  userId     String    @id
  provider   String // "claude" | "openai" | "gemini" | "ollama"
  apiKeyEnc  String // base64(iv[12] || authTag[16] || ciphertext). ollama면 빈 문자열 허용
  last4      String // 원문 API Key의 마지막 4자 (UI 표시용)
  // ollama 로컬 테스트용 — 다른 provider는 null
  baseUrl    String?
  modelId    String?
  verified   Boolean   @default(false)
  verifiedAt DateTime?
  lastError  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ──── Billing / 정기결제 (Seed 14 scaffold, 2026-04-22) ────
// 교사 계정 Free ↔ Pro 구독 상태. 1 user = 1 subscription (userId PK).
// PG는 토스페이먼츠 빌링키 방식을 기본으로 하고, provider 필드로 추후
// 포트원 등 확장할 수 있게 남겼다. billingKey는 결제 시 사용자 확인 불필요 —
// 반드시 서버 프록시로만 사용, 절대 클라이언트에 내려가지 않는다.
model TeacherSubscription {
  userId             String    @id
  // "free" | "pro_monthly" | "pro_yearly"
  plan               String    @default("free")
  // "active" | "trial" | "past_due" | "canceled" | "paused"
  status             String    @default("active")
  pgProvider         String    @default("toss") // "toss" | "portone"
  pgCustomerKey      String?   @unique
  pgBillingKey       String?
  pgBillingKeyLast4  String?
  amount             Int       @default(0) // KRW per period
  currency           String    @default("KRW")
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  canceledAt         DateTime? // 구독 취소 예약 — 기간 만료 시점에 status=canceled
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  events   PaymentEvent[]
}

// 결제·환불 이벤트 감사 로그. 웹훅·수동 호출 모두 여기에 insert.
// rawPayload는 JSON(토스 응답 원본). 리콘실리에이션용.
model PaymentEvent {
  id             String   @id @default(cuid())
  userId         String
  // TeacherSubscription.userId. 구독 취소 후에도 이력은 남겨야 하므로 FK SetNull.
  subscriptionId String?
  // "charge" | "refund" | "cancel" | "billing_key_issued" | "webhook"
  type           String
  amount         Int      @default(0)
  currency       String   @default("KRW")
  // "pending" | "succeeded" | "failed"
  status         String   @default("pending")
  pgOrderId      String?  @unique
  pgPaymentKey   String?
  rawPayload     Json?
  errorMessage   String?
  createdAt      DateTime @default(now())

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription TeacherSubscription? @relation(fields: [subscriptionId], references: [userId], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([subscriptionId])
}

// ──── Canva Connect API token store ────
// Canva as an IdP — teachers OAuth into their Canva account so we can call
// Canva's REST API on their behalf (e.g. list designs, export PDF). Storing
// tokens in DB (not in-memory Map) so Vercel Function cold starts don't
// silently log the teacher out between requests.
//
// `pkceVerifier` holds the transient verifier during the authorize → callback
// round-trip. It's cleared on successful exchangeCode. For a long-idle user
// whose refresh token has also expired we simply require re-authorize.
model CanvaConnectAccount {
  userId       String    @id
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  pkceVerifier String?
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ──── Classroom system ────

model Classroom {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique // 6-char alphanumeric, teacher shares this
  teacherId String
  createdAt DateTime @default(now())

  teacher         User                      @relation(fields: [teacherId], references: [id])
  students        Student[]
  boards          Board[]                   @relation("ClassroomBoards")
  plantAllows     ClassroomPlantAllow[]
  inviteCodes     ClassInviteCode[]
  assessments     AssessmentTemplate[]
  roleAssignments ClassroomRoleAssignment[]
  currency        ClassroomCurrency?
  studentAccounts StudentAccount[]
  storeItems      StoreItem[]
  rolePermissions ClassroomRolePermission[]
  djPlayEvents    DjPlayEvent[]
  aiFeedbacks     AiFeedback[]

  @@index([teacherId])
  @@index([code])
}

model Student {
  id             String   @id @default(cuid())
  classroomId    String
  number         Int? // 출석번호
  name           String
  qrToken        String   @unique // UUID — encoded in QR
  textCode       String   @unique // 6-char alphanumeric — manual entry fallback
  sessionVersion Int      @default(1)
  createdAt      DateTime @default(now())

  classroom             Classroom                 @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  quizPlayers           QuizPlayer[]
  studentPlants         StudentPlant[]
  assets                StudentAsset[]
  breakoutMemberships   BreakoutMembership[]
  parents               ParentChildLink[]
  parentInvites         ParentInviteCode[]
  cardsAuthored         Card[]                    @relation("StudentCardAuthor")
  oauthAuthCodes        OAuthAuthCode[]
  oauthAccessTokens     OAuthAccessToken[]
  oauthRefreshTokens    OAuthRefreshToken[]
  canvaAppLink          CanvaAppLink?
  assignmentSlots       AssignmentSlot[]          @relation("StudentAssignmentSlots")
  cardAuthors           CardAuthor[]              @relation("StudentCardAuthors")
  assessmentSubmissions AssessmentSubmission[]
  roleAssignments       ClassroomRoleAssignment[]
  account               StudentAccount?
  vibeProjectsAuthored  VibeProject[]             @relation("VibeProjectAuthor")
  vibeSessions          VibeSession[]             @relation("VibeSessionAuthor")
  vibeReviews           VibeReview[]              @relation("VibeReviewer")
  vibePlaySessions      VibePlaySession[]         @relation("VibePlayer")
  boardResponses        BoardResponse[]           @relation("StudentBoardResponses")
  aiFeedbacks           AiFeedback[]

  @@unique([classroomId, number])
  @@index([classroomId])
  @@index([qrToken])
  @@index([textCode])
}

// ──── AI 평어 (2026-04-24) ────
// 교사가 학생별·단원별·평가항목별로 AI 가 생성한 평어(생기부 톤 문장)을 저장.
// 영속 정책 B: 교사가 모달에서 "보내기" 버튼을 누른 시점에만 row 생성/UPDATE.
// 같은 (학생, 과목, 단원, 평가항목) 조합 재생성 시 동일 row UPSERT (덮어쓰기).
// 외부 컴패니언 앱 Aura 가 GET /api/external/feedbacks 로 풀해 종합.
// 학생/학부모 노출 X — 교사 전용.
model AiFeedback {
  id          String   @id @default(cuid())
  teacherId   String
  classroomId String
  studentId   String
  subject     String   // v1 'art', 향후 다과목 확장 대비 free string
  unit        String
  criterion   String
  comment     String   @db.Text
  model       String   // 사용된 LLM model id (감사·디버깅용)
  sentAt      DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher   User      @relation("TeacherAiFeedbacks", fields: [teacherId], references: [id], onDelete: Cascade)
  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, subject, unit, criterion])
  @@index([classroomId, updatedAt])
  @@index([teacherId, updatedAt])
}

// layout: "freeform" | "grid" | "stream" | "columns" | "assignment" | "quiz" | "plant-roadmap" | "event-signup" | "drawing" | "breakout" | "vibe-arcade" | "vibe-gallery"
// (validated in app via zod)
model Board {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  layout      String   @default("freeform")
  description String   @default("")
  classroomId String?
  createdAt   DateTime @default(now())
  // classroom-boards-tab "🟢 새 활동" 배지가 실제 활동을 반영하도록 추가.
  // @updatedAt은 Board 행 자체가 update 될 때만 자동 bump되므로, 카드/섹션
  // mutation 라우트에서 부모 board.update({updatedAt: new Date()})로 명시적
  // touch 한다 (src/app/api/cards/**, src/app/api/sections/**).
  updatedAt   DateTime @updatedAt

  // ── Event-signup (ES-1) ────────────────────────────────────────────
  // Public link access. "classroom" = NextAuth or classroom-scoped only.
  // "public-link" = anyone with accessToken in URL can view the signup form.
  accessMode          String    @default("classroom")
  accessToken         String?   @unique
  eventPosterUrl      String?
  applicationStart    DateTime?
  applicationEnd      DateTime?
  eventStart          DateTime?
  eventEnd            DateTime?
  venue               String?
  maxSelections       Int?
  videoPolicy         String    @default("optional") // "none" | "optional" | "required"
  videoProviders      String    @default("youtube") // csv
  maxVideoDurationSec Int?
  maxVideoSizeMb      Int?
  allowTeam           Boolean   @default(false)
  maxTeamSize         Int?
  customQuestions     String    @default("[]") // JSON-encoded question[]
  announceMode        String    @default("private") // "public-list" | "private-search" | "private"
  requireApproval     Boolean   @default(false)
  askName             Boolean   @default(true)
  askGradeClass       Boolean   @default(true)
  askStudentNumber    Boolean   @default(true)
  askContact          Boolean   @default(false)

  // ── Assignment board (AB-1) ────────────────────────────────────────
  assignmentGuideText String?   @default("")
  assignmentAllowLate Boolean   @default(true)
  assignmentDeadline  DateTime?

  // ── Question board (QB-1, 2026-04-23) ─────────────────────────────
  // layout="question-board" 전용. 교사가 주제를 설정하고 학생들이 자유 텍스트
  // 응답을 올린다. questionVizMode 는 교사가 선택한 시각화 모드.
  questionPrompt    String?
  questionVizMode   String     @default("word-cloud")

  classroom          Classroom?          @relation("ClassroomBoards", fields: [classroomId], references: [id], onDelete: SetNull)
  members            BoardMember[]
  cards              Card[]
  sections           Section[]
  submissions        Submission[]
  quizzes            Quiz[]
  studentPlants      StudentPlant[]
  breakoutAssignment BreakoutAssignment?
  assignmentSlots    AssignmentSlot[]
  vibeArcadeConfig   VibeArcadeConfig?
  vibeProjects       VibeProject[]
  djPlayEvents       DjPlayEvent[]
  responses          BoardResponse[]
}

// Question Board 응답 (QB-1, 2026-04-23).
// 하나의 Board(layout=question-board) 에 N 개 응답. 학생 또는 교사가 작성.
// Board 삭제 시 cascade, Student/User 삭제 시 응답은 남지만 authorship 해지.
model BoardResponse {
  id        String   @id @default(cuid())
  boardId   String
  studentId String?
  userId    String?
  text      String
  createdAt DateTime @default(now())

  board   Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  student Student? @relation("StudentBoardResponses", fields: [studentId], references: [id], onDelete: SetNull)
  user    User?    @relation("UserBoardResponses", fields: [userId], references: [id], onDelete: SetNull)

  @@index([boardId, createdAt])
  @@index([boardId, studentId])
}

// Columns/Kanban용 섹션 (grid/stream에선 사용 안 함)
model Section {
  id          String  @id @default(cuid())
  boardId     String
  title       String
  order       Int     @default(0)
  // shared-column-sort (2026-04-20): 교사가 선택한 칼럼별 정렬 모드가
  // 학생 화면에도 공유되도록 서버에 저장. "manual" | "newest" | "oldest"
  // | "title". null → 클라이언트가 "manual"로 처리(기존 행 하위호환).
  sortMode    String?
  // Breakout view (T0-①): teacher-rotatable access token.
  // null = no public share link. When set, anyone with the token can view the
  // section-isolated Breakout route. Rotating replaces the value, invalidating
  // previously distributed links. See src/lib/rbac.ts#viewSection.
  accessToken String? @unique

  board               Board                @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards               Card[]               @relation("SectionCards")
  breakoutMemberships BreakoutMembership[]

  @@index([boardId])
}

// RBAC core: one row per (board, user).
// role: "owner" | "editor" | "viewer" (validated in app via zod)
model BoardMember {
  id      String @id @default(cuid())
  boardId String
  userId  String
  role    String

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([userId])
}

model Card {
  id                 String   @id @default(cuid())
  boardId            String
  sectionId          String?
  authorId           String
  title              String
  content            String
  color              String?
  imageUrl           String?
  // 160×120 WebP thumbnail generated from imageUrl on assignment submit
  // (AC-12). Populated by resizeToWebPThumbUrl → blob. Falls back to
  // imageUrl in slotRowToDTO when null so legacy rows keep working.
  thumbUrl           String?
  linkUrl            String?
  linkTitle          String?
  linkDesc           String?
  linkImage          String?
  videoUrl           String?
  // card-file-attachment (2026-04-20): 일반 문서 첨부(PDF/DOCX/XLSX/PPTX/HWP
  // /TXT/ZIP). fileName은 원본 파일 이름(사용자 노출), fileSize는 byte,
  // fileMimeType은 서버 검증된 MIME. 4개 모두 null → 파일 첨부 없음.
  fileUrl            String?
  fileName           String?
  fileSize           Int?
  fileMimeType       String?
  // Student author (when the card was published from the Canva Content
  // Publisher app while the student was logged into Aura). Makes the card
  // a first-class child artifact — parent viewer filters on this FK to show
  // "내 자녀의 카드", and future reporting / ownership logic keys off here.
  studentAuthorId    String?
  // Denormalized display label (= student.name) captured at publish time so
  // the board UI can render "작성: 가온" without joining Student.
  externalAuthorName String?
  // Canva design identifier when the card was published from the Canva
  // Content Publisher app (or a pasted Canva design URL with successful
  // resolve). Enables CanvaEmbedSlot's thumbnail+live toggle UX.
  canvaDesignId      String?
  x                  Float    @default(0)
  y                  Float    @default(0)
  width              Float    @default(240)
  height             Float    @default(160)
  order              Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // DJ queue status (layout="dj-queue"만 사용). null = 비-큐 카드.
  // "pending" | "approved" | "played" | "rejected"
  queueStatus String?

  board            Board             @relation(fields: [boardId], references: [id], onDelete: Cascade)
  section          Section?          @relation("SectionCards", fields: [sectionId], references: [id], onDelete: SetNull)
  author           User              @relation(fields: [authorId], references: [id])
  studentAuthor    Student?          @relation("StudentCardAuthor", fields: [studentAuthorId], references: [id], onDelete: SetNull)
  assetAttachments AssetAttachment[] @relation("CardAssetAttachments")
  assignmentSlot   AssignmentSlot?   @relation("AssignmentSlotCard")
  authors          CardAuthor[]
  attachments      CardAttachment[]  @relation("CardAttachments")

  @@index([boardId])
  @@index([sectionId])
  @@index([authorId])
  @@index([studentAuthorId])
}

// multi-attachment (2026-04-20): 카드 1개에 이미지·동영상·파일 여러 개를
// 붙일 수 있는 정규화 테이블. `kind`는 "image"|"video"|"file". 레거시
// Card.imageUrl/videoUrl/fileUrl 단일 필드는 별개로 계속 존재하며,
// attachments 배열이 비어있는 카드에 한해 렌더 fallback으로 사용됨.
model CardAttachment {
  id         String   @id @default(cuid())
  cardId     String
  kind       String   // "image" | "video" | "file"
  url        String
  fileName   String?
  fileSize   Int?
  mimeType   String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  card       Card     @relation("CardAttachments", fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

model Submission {
  id        String   @id @default(cuid())
  boardId   String
  userId    String? // nullable for public event-signup submissions (ES-1)
  content   String   @default("")
  linkUrl   String?
  fileUrl   String?
  // status (event-signup adds): "pending_approval" | "submitted" | "approved" | "rejected"
  // status (assignment keeps): "submitted" | "reviewed" | "returned"
  status    String   @default("submitted")
  feedback  String?
  grade     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Event-signup applicant fields (ES-1) ─────────────────────────
  submitToken      String? @unique // public self-auth for /my page
  applicantName    String?
  applicantGrade   Int?
  applicantClass   Int?
  applicantNumber  Int?
  applicantContact String?
  ipHash           String?
  teamName         String?
  teamMembers      String  @default("[]") // JSON — {name,grade,class,number}[]
  answers          String  @default("{}") // JSON — {questionId: value}
  videoUrl         String?
  videoProvider    String? // "youtube" | "cfstream"
  videoId          String?
  videoThumbnail   String?
  scoreAvg         Float?

  // ── Assignment-slot linkage (AB-1) ─────────────────────────────────
  // Nullable for backward-compat with event-signup submissions that never had
  // a slot. When present, @unique pins one Submission to one slot so student
  // overwrites happen in-place (no history — decisions Q2).
  assignmentSlotId String?         @unique
  assignmentSlot   AssignmentSlot? @relation(fields: [assignmentSlotId], references: [id], onDelete: SetNull)

  board   Board              @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user    User?              @relation(fields: [userId], references: [id])
  reviews SubmissionReview[]

  @@index([boardId])
  @@index([userId])
  @@index([boardId, status])
  @@index([ipHash, createdAt])
}

// ──── Assignment-board (AB-1) ────
// One row per (boardId, studentId) captured at board creation time. v1 hard-
// caps count ≤ 30 (Galaxy Tab S6 Lite perf budget). slotNumber is a snapshot
// of Student.number at creation; Q6 decision — number changes don't propagate.
model AssignmentSlot {
  id               String    @id @default(cuid())
  boardId          String
  studentId        String
  slotNumber       Int
  cardId           String    @unique
  // submissionStatus: "assigned"|"submitted"|"viewed"|"returned"|"reviewed"|"orphaned"
  submissionStatus String    @default("assigned")
  // gradingStatus: "not_graded"|"graded"|"released"
  gradingStatus    String    @default("not_graded")
  grade            String?
  viewedAt         DateTime?
  returnedAt       DateTime?
  returnReason     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  board      Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  student    Student     @relation("StudentAssignmentSlots", fields: [studentId], references: [id], onDelete: Restrict)
  card       Card        @relation("AssignmentSlotCard", fields: [cardId], references: [id], onDelete: Restrict)
  submission Submission?

  @@unique([boardId, studentId])
  @@unique([boardId, slotNumber])
  @@index([studentId])
}

// ── Event-signup reviews (ES-1, ES-9) ─────────────────────────────
model SubmissionReview {
  id           String   @id @default(cuid())
  submissionId String
  reviewerId   String
  score        Int
  comment      String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewer   User       @relation(fields: [reviewerId], references: [id])

  @@unique([submissionId, reviewerId])
  @@index([submissionId])
  @@index([reviewerId])
}

// ──── Quiz system ────

model Quiz {
  id           String   @id @default(cuid())
  boardId      String
  title        String   @default("")
  sourceFile   String? // uploaded PDF/PPT filename
  sourceText   String? // extracted text (for reference)
  roomCode     String   @unique // 6-digit code for students to join
  status       String   @default("waiting") // "waiting" | "active" | "finished"
  currentQ     Int      @default(-1) // index of current question (-1 = not started)
  difficulty   String? // "easy" | "medium" | "hard" (quiz-extensions B2)
  parentQuizId String? // clone source Quiz.id — no FK so source delete is allowed (B4)
  createdAt    DateTime @default(now())

  board     Board          @relation(fields: [boardId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  players   QuizPlayer[]

  @@index([boardId])
  @@index([roomCode])
  @@index([parentQuizId])
}

model QuizQuestion {
  id        String @id @default(cuid())
  quizId    String
  order     Int    @default(0)
  question  String
  optionA   String
  optionB   String
  optionC   String
  optionD   String
  answer    String // "A" | "B" | "C" | "D"
  timeLimit Int    @default(20) // seconds

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([quizId])
}

model QuizPlayer {
  id        String   @id @default(cuid())
  quizId    String
  studentId String?
  nickname  String
  score     Int      @default(0)
  joinedAt  DateTime @default(now())

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student Student?     @relation(fields: [studentId], references: [id])
  answers QuizAnswer[]

  @@unique([quizId, studentId])
  @@index([quizId])
  @@index([studentId])
}

model QuizAnswer {
  id         String   @id @default(cuid())
  questionId String
  playerId   String
  selected   String // "A" | "B" | "C" | "D"
  correct    Boolean
  timeMs     Int      @default(0) // answer time in ms
  createdAt  DateTime @default(now())

  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  player   QuizPlayer   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([questionId, playerId])
  @@index([questionId])
  @@index([playerId])
}

// ──── Plant Journal (PJ-1 ~ PJ-6) ────

model PlantSpecies {
  id         String   @id @default(cuid())
  key        String   @unique // "tomato", "strawberry" — program identifier
  nameKo     String
  emoji      String
  difficulty String   @default("easy") // "easy" | "medium" | "hard"
  season     String   @default("spring") // "spring" | "summer" | "fall" | "winter" | "all"
  notes      String   @default("")
  createdAt  DateTime @default(now())

  stages        PlantStage[]
  allows        ClassroomPlantAllow[]
  studentPlants StudentPlant[]
}

model PlantStage {
  id                String @id @default(cuid())
  speciesId         String
  order             Int
  key               String
  nameKo            String
  description       String @default("")
  icon              String
  observationPoints String // JSON-encoded string[]

  species      PlantSpecies       @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  currentFor   StudentPlant[]     @relation("StudentPlantCurrentStage")
  observations PlantObservation[]

  @@unique([speciesId, order])
  @@index([speciesId])
}

model ClassroomPlantAllow {
  id          String   @id @default(cuid())
  classroomId String
  speciesId   String
  createdAt   DateTime @default(now())

  classroom Classroom    @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  species   PlantSpecies @relation(fields: [speciesId], references: [id], onDelete: Cascade)

  @@unique([classroomId, speciesId])
  @@index([classroomId])
  @@index([speciesId])
}

model StudentPlant {
  id             String   @id @default(cuid())
  boardId        String
  studentId      String
  speciesId      String
  nickname       String
  currentStageId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  board        Board              @relation(fields: [boardId], references: [id], onDelete: Cascade)
  student      Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  species      PlantSpecies       @relation(fields: [speciesId], references: [id])
  currentStage PlantStage         @relation("StudentPlantCurrentStage", fields: [currentStageId], references: [id])
  observations PlantObservation[]

  @@unique([boardId, studentId])
  @@index([boardId])
  @@index([studentId])
  @@index([speciesId])
  @@index([currentStageId])
}

model PlantObservation {
  id             String   @id @default(cuid())
  studentPlantId String
  stageId        String
  memo           String   @default("")
  noPhotoReason  String?
  observedAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  studentPlant     StudentPlant            @relation(fields: [studentPlantId], references: [id], onDelete: Cascade)
  stage            PlantStage              @relation(fields: [stageId], references: [id])
  images           PlantObservationImage[]
  assetAttachments AssetAttachment[]       @relation("PlantObservationAssetAttachments")

  @@index([studentPlantId])
  @@index([stageId])
  @@index([studentPlantId, stageId])
}

model PlantObservationImage {
  id            String   @id @default(cuid())
  observationId String
  url           String
  thumbnailUrl  String?
  order         Int      @default(0)
  createdAt     DateTime @default(now())

  observation PlantObservation @relation(fields: [observationId], references: [id], onDelete: Cascade)

  @@index([observationId])
}

// ──── Drawpile student-asset library (partial scope — schema + stub) ────
// StudentAsset = a student-owned image (uploaded or produced by Drawpile).
// classroomId is denormalized for fast classroom-scoped gallery scans.
// source: "upload" (current path) | "drawpile" (set later when Drawpile fork
// posts back via postMessage bridge — see docs/drawpile-protocol.md).
model StudentAsset {
  id              String   @id @default(cuid())
  studentId       String
  classroomId     String
  title           String   @default("")
  fileUrl         String
  thumbnailUrl    String?
  width           Int?
  height          Int?
  format          String   @default("image/png")
  sizeBytes       Int      @default(0)
  isSharedToClass Boolean  @default(false)
  source          String   @default("upload")
  drawpileFileId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student     Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  attachments AssetAttachment[]

  @@index([studentId])
  @@index([classroomId])
  @@index([classroomId, isSharedToClass])
}

// CardAuthor = N:N join row between Card and Student, with a denormalised
// displayName so author names survive student rename/soft-delete. Order
// enforces a stable primary author (order=0) which Card.studentAuthorId +
// Card.externalAuthorName mirror for backward-compatibility. See
// tasks/2026-04-15-card-author-multi/phase3/design_doc.md §1.
model CardAuthor {
  id          String   @id @default(cuid())
  cardId      String
  studentId   String?
  displayName String
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  card    Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  student Student? @relation("StudentCardAuthors", fields: [studentId], references: [id], onDelete: SetNull)

  @@unique([cardId, studentId])
  @@index([cardId, order])
  @@index([studentId])
}

// AssetAttachment = join row linking a StudentAsset to a Card or
// PlantObservation. Exactly one of (cardId, observationId) is expected to be
// set at attach time. Both nullable to keep Prisma relation checks simple.
model AssetAttachment {
  id            String   @id @default(cuid())
  assetId       String
  cardId        String?
  observationId String?
  createdAt     DateTime @default(now())

  asset       StudentAsset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  card        Card?             @relation("CardAssetAttachments", fields: [cardId], references: [id], onDelete: Cascade)
  observation PlantObservation? @relation("PlantObservationAssetAttachments", fields: [observationId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([cardId])
  @@index([observationId])
}

// ──── Breakout Room (BR-1 ~ BR-4) ────
// BreakoutTemplate — reusable group-learning blueprints (8 system + teacher/school custom).
// `structure` JSON schema:
//   { sectionsPerGroup: [{title, role: "group-copy"|"role-expert"|"role-home",
//                         defaultCards?: [{title, content}]}],
//     sharedSections?: [{title, role: "teacher-pool"}] }
// On board creation the structure is deep-cloned into Section rows → template
// edits never retroactively affect existing boards (decisions Q6).
model BreakoutTemplate {
  id                    String   @id @default(cuid())
  key                   String   @unique
  name                  String
  description           String
  tier                  String   @default("free") // "free" | "pro"
  requiresPro           Boolean  @default(false)
  scope                 String   @default("system") // "system" | "teacher" | "school"
  ownerId               String?
  structure             Json
  recommendedVisibility String   @default("own-only") // "own-only" | "peek-others"
  defaultGroupCount     Int      @default(4)
  defaultGroupCapacity  Int      @default(6)
  createdAt             DateTime @default(now())

  owner       User?                @relation("TemplateOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  assignments BreakoutAssignment[]

  @@index([ownerId])
  @@index([scope])
}

// BreakoutAssignment — one per Breakout Board. Tracks deploy + visibility state.
model BreakoutAssignment {
  id                 String   @id @default(cuid())
  boardId            String   @unique
  templateId         String
  deployMode         String   @default("link-fixed") // "link-fixed" | "self-select" | "teacher-assign"
  groupCount         Int      @default(4)
  groupCapacity      Int      @default(6)
  visibilityOverride String? // null = use template.recommendedVisibility
  status             String   @default("active") // "active" | "archived"
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  board    Board                @relation(fields: [boardId], references: [id], onDelete: Cascade)
  template BreakoutTemplate     @relation(fields: [templateId], references: [id])
  members  BreakoutMembership[]

  @@index([templateId])
}

// BreakoutMembership — links a Student to their group Section (role for Jigsaw).
// Foundation does not populate this; BR-5 (deploy modes) writes rows on self-select
// or teacher-assign. `@@unique([sectionId, studentId])` prevents double-membership.
model BreakoutMembership {
  id           String   @id @default(cuid())
  assignmentId String
  sectionId    String
  studentId    String
  role         String? // "expert" | "home" (Jigsaw) | null
  joinedAt     DateTime @default(now())

  assignment BreakoutAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  section    Section            @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  student    Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sectionId, studentId])
  @@index([assignmentId])
  @@index([studentId])
}

// ──── Parent Viewer Access (PV-1 ~ PV-5) ────
// Seed 7 (2026-04-12-parent-viewer-access). Read-only viewer for guardians.
// Crockford Base32 6-char invite codes + magic-link auth + 7-day sessions.
// All queries in /parent/* must route through parentScopeMiddleware
// (src/lib/parent-scope.ts). See canva project/plans/parent-viewer-roadmap.md
// for the single-source-of-truth child-scope matrix.

model Parent {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  tier            String    @default("free") // "free" | "pro"
  parentDeletedAt DateTime? // soft delete; 90d anonymization Cron (PV-11)
  anonymizedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  children ParentChildLink[]
  sessions ParentSession[]
  invites  ParentInviteCode[] @relation("IssuedToEmail")

  @@index([email])
  @@index([parentDeletedAt])
}

// parent-class-invite-v2 — ParentLinkStatus lifecycle.
//   pending  → (approve) → active
//   pending  → (reject | code_rotated | auto_expired) → rejected
//   active   → (teacher_revoked | classroom_deleted | year_end | parent_self_leave) → revoked
// rejected/revoked are dead-end. See src/lib/parent-link-state.ts for the
// transition validator used by every state-changing endpoint.
enum ParentLinkStatus {
  pending
  active
  rejected
  revoked
}

// UI dropdown for teacher reject action exposes only the first 3 values.
// System-originated reject uses code_rotated | auto_expired | classroom_deleted.
enum ParentRejectedReason {
  wrong_child
  not_parent
  other
  code_rotated
  auto_expired
  classroom_deleted
}

// v1 had 3 revoked reasons; v2 adds 4 more (audit completeness — system
// transitions that originate from pending→rejected ALSO get a matching
// revokedReason row for downstream reporting).
enum ParentRevokedReason {
  teacher_revoked
  year_end
  parent_self_leave
  rejected_by_teacher
  auto_expired_pending
  code_rotated
  classroom_deleted
}

model ParentChildLink {
  id        String @id @default(cuid())
  parentId  String
  studentId String

  // v2 lifecycle
  status ParentLinkStatus @default(pending)

  // audit — set as status transitions
  requestedAt    DateTime              @default(now())
  approvedAt     DateTime?
  approvedById   String?
  rejectedAt     DateTime?
  rejectedById   String?
  rejectedReason ParentRejectedReason?
  revokedAt      DateTime?
  revokedById    String?
  revokedReason  ParentRevokedReason?

  createdAt DateTime  @default(now())
  deletedAt DateTime? // soft delete (R-07 v1 compat)

  parent     Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student    Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  approvedBy User?   @relation("LinkApprovedBy", fields: [approvedById], references: [id])
  rejectedBy User?   @relation("LinkRejectedBy", fields: [rejectedById], references: [id])
  revokedBy  User?   @relation("LinkRevokedBy", fields: [revokedById], references: [id])

  @@unique([parentId, studentId])
  @@index([studentId])
  @@index([parentId])
  @@index([status, requestedAt])
  @@index([deletedAt])
}

// parent-class-invite-v2 — classroom-scoped invite code.
// One active (rotatedAt IS NULL) row per classroom, enforced by a partial
// unique index declared in the migration SQL (Prisma schema doesn't support
// partial uniques directly).
model ClassInviteCode {
  id          String    @id @default(cuid())
  classroomId String
  code        String    @unique
  codeHash    String    @unique
  issuedById  String
  expiresAt   DateTime?
  maxUses     Int?
  rotatedAt   DateTime?
  createdAt   DateTime  @default(now())

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  issuedBy  User      @relation("ClassInviteIssued", fields: [issuedById], references: [id])

  @@index([classroomId])
  @@index([rotatedAt])
}

model ParentInviteCode {
  id             String    @id @default(cuid())
  studentId      String
  issuedByUserId String // teacher
  code           String    @unique // Crockford Base32 6 chars, normalized upper
  codeHash       String    @unique // sha256 — timing-safe verify + revoke safety
  maxUses        Int       @default(3)
  usesCount      Int       @default(0)
  failedAttempts Int       @default(0) // auto-revoke at 10
  expiresAt      DateTime // +48h from issue
  revokedAt      DateTime?
  boundToEmail   String? // optional binding (teacher knows parent email)
  createdAt      DateTime  @default(now())

  student  Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  issuedBy User    @relation("TeacherInvite", fields: [issuedByUserId], references: [id])
  parent   Parent? @relation("IssuedToEmail", fields: [boundToEmail], references: [email])

  @@index([studentId])
  @@index([expiresAt])
  @@index([boundToEmail])
}

model ParentSession {
  id               String    @id @default(cuid())
  parentId         String
  sessionToken     String    @unique // plaintext cookie value (32-byte base64url)
  tokenHash        String    @unique // sha256 of sessionToken
  userAgent        String?
  ipHash           String?
  expiresAt        DateTime // +7d
  sessionRevokedAt DateTime?
  createdAt        DateTime  @default(now())
  lastSeenAt       DateTime?

  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@index([sessionToken])
  @@index([tokenHash])
  @@index([expiresAt])
}

// ──── OAuth 2.0 Provider (Seed — oauth2-provider task) ────
// Aura acts as an OAuth 2.0 Authorization Server for the Canva Content
// Publisher app. Students log into Aura, grant the Canva app `cards:write`
// via an on-device consent screen, then Canva exchanges the auth code for
// an access + refresh token pair that is STUDENT-scoped (not teacher-PAT).
// This replaces bundling a shared teacher PAT in the Canva app binary.
//
// Protocol: RFC 6749 Authorization Code + RFC 7636 PKCE (S256).
// Canva-specific details: https://www.canva.dev/docs/apps/authenticating-users/oauth/
// See src/lib/oauth-server.ts for the runtime helpers.

model OAuthClient {
  id           String   @id // e.g. "canva" — visible client_id
  name         String
  // bcrypt hash of the client secret. Client secrets are rotated by
  // regenerating this row; no plaintext is kept.
  secretHash   String
  // JSON-encoded array of absolute redirect URIs the client is allowed to
  // receive authorization codes at. Canva registers exactly one per app.
  redirectUris String
  // JSON-encoded array of scope strings (e.g. ["cards:write"]). Authorize
  // requests are rejected if they request a scope not in this list.
  scopes       String
  pkceRequired Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  authCodes     OAuthAuthCode[]
  accessTokens  OAuthAccessToken[]
  refreshTokens OAuthRefreshToken[]
}

model OAuthAuthCode {
  // 40-char base64url random — surfaced as `code` query param to client.
  // One-shot: consumedAt is set on the first /oauth/token exchange. Re-use
  // triggers invalidation of the linked access/refresh tokens per RFC 6749.
  //
  // Subject = student (Canva pairing) OR user (Aura companion teacher OAuth).
  // CHECK 제약: 정확히 하나만 NOT NULL. 마이그레이션 20260424_oauth_teacher_subject.
  code                String    @id
  studentId           String?
  userId              String?
  clientId            String
  redirectUri         String
  scope               String
  codeChallenge       String // PKCE S256 base64url
  codeChallengeMethod String    @default("S256")
  state               String? // opaque, echoed back; stored for audit
  expiresAt           DateTime // +10 min from issuance
  consumedAt          DateTime?
  createdAt           DateTime  @default(now())

  student Student?    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  user    User?       @relation("UserOAuthAuthCodes", fields: [userId], references: [id], onDelete: Cascade)
  client  OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([userId])
  @@index([clientId])
  @@index([expiresAt])
}

model OAuthAccessToken {
  // SHA-256 hex of the plaintext token. Plaintext is only ever returned in
  // the token exchange response and never stored.
  tokenHash      String    @id
  // 8-char base62 prefix extracted from plaintext — O(1) lookup index. The
  // plaintext returned is `aurastu_{prefix}_{secret}` (student) or
  // `auratea_{prefix}_{secret}` (teacher).
  tokenPrefix    String    @unique
  studentId      String?
  userId         String?
  clientId       String
  scope          String
  expiresAt      DateTime // +30 days default (student); +1h (teacher)
  revokedAt      DateTime?
  // When this access token was rotated out of a refresh_token grant we keep
  // the id of the new refresh token so audits can trace chains.
  refreshTokenId String?
  createdAt      DateTime  @default(now())
  lastUsedAt     DateTime?

  student Student?    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  user    User?       @relation("UserOAuthAccessTokens", fields: [userId], references: [id], onDelete: Cascade)
  client  OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tokenPrefix])
  @@index([studentId])
  @@index([userId])
  @@index([expiresAt])
}

model OAuthRefreshToken {
  tokenHash       String    @id
  tokenPrefix     String    @unique
  studentId       String?
  userId          String?
  clientId        String
  scope           String
  expiresAt       DateTime // +180 days default (student); +30 days (teacher)
  revokedAt       DateTime?
  // Parent refresh token (set when the current token was rotated out of a
  // prior refresh grant). Used to detect refresh-token reuse attacks — if a
  // revoked refresh is presented, we also revoke the chain.
  parentTokenHash String?
  createdAt       DateTime  @default(now())

  student Student?    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  user    User?       @relation("UserOAuthRefreshTokens", fields: [userId], references: [id], onDelete: Cascade)
  client  OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tokenPrefix])
  @@index([studentId])
  @@index([userId])
  @@index([expiresAt])
}

// Maps a Canva user (per the Canva Apps SDK's getCanvaUserToken JWT `sub`
// claim) to one of our Student rows. Populated during OAuth consent when
// the student authorizes the Canva app. Backend uses this table to resolve
// Canva JWT Bearer tokens to an Aura-board student for external/* routes.
model CanvaAppLink {
  canvaUserId String   @id
  studentId   String   @unique
  scope       String   @default("cards:write")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

// ──── Assessment (performance-assessment-autograde MVP-0) ────

model AssessmentTemplate {
  id          String   @id @default(cuid())
  classroomId String
  boardId     String? // Board(layout="assessment") shell link. nullable — template can exist without a board.
  title       String
  durationMin Int      @default(30)
  createdById String // teacher User.id
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  classroom   Classroom              @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  questions   AssessmentQuestion[]
  submissions AssessmentSubmission[]

  @@index([classroomId])
  @@index([boardId])
}

model AssessmentQuestion {
  id         String   @id @default(cuid())
  templateId String
  order      Int
  kind       String // MVP-0 accepts "MCQ" only; future: "SHORT"|"OX"|"NUMERIC"|"ESSAY".
  prompt     String
  // MCQ payload: { choices: [{id, text}], correctChoiceIds: string[] }
  payload    Json
  maxScore   Int      @default(1)
  createdAt  DateTime @default(now())

  template AssessmentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  answers  AssessmentAnswer[]

  @@unique([templateId, order])
  @@index([templateId])
}

model AssessmentSubmission {
  id          String    @id @default(cuid())
  templateId  String
  studentId   String
  status      String    @default("in_progress") // "in_progress" | "submitted"
  startedAt   DateTime  @default(now())
  endAt       DateTime // = startedAt + durationMin
  submittedAt DateTime?
  createdAt   DateTime  @default(now())

  template       AssessmentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  student        Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers        AssessmentAnswer[]
  gradebookEntry GradebookEntry?

  @@unique([templateId, studentId])
  @@index([templateId])
  @@index([studentId])
  @@index([status])
}

model AssessmentAnswer {
  id           String   @id @default(cuid())
  submissionId String
  questionId   String
  // MCQ payload: { selectedChoiceIds: string[] }
  // SHORT payload: { textAnswer: string }
  // MANUAL payload: { textAnswer: string }
  payload      Json
  autoScore    Int?
  manualScore  Int? // teacher-assigned for MANUAL questions; null = pending
  updatedAt    DateTime @updatedAt

  submission AssessmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question   AssessmentQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, questionId])
  @@index([submissionId])
}

model GradebookEntry {
  id           String    @id @default(cuid())
  submissionId String    @unique
  finalScore   Int
  releasedAt   DateTime? // Classroom.gradebookReleasePolicy="teacher_manual" gate
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  submission AssessmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([releasedAt])
}

// ──── DJ Board — classroom role system ────
// 학급 내 학생에게 "DJ"/"사서"/"은행원" 등의 역할을 부여하고, 해당 역할이
// 특정 보드 레이아웃에서 BoardMember(owner/editor) 권한을 승계하도록 한다.
// 데이터 주도 설계 — 새 역할 추가 = row insert, 코드 변경 없음.

model ClassroomRoleDef {
  id          String   @id @default(cuid())
  key         String   @unique
  labelKo     String
  emoji       String?
  description String   @default("")
  createdAt   DateTime @default(now())

  grants      BoardLayoutRoleGrant[]
  assignments ClassroomRoleAssignment[]
}

model BoardLayoutRoleGrant {
  id              String   @id @default(cuid())
  classroomRoleId String
  boardLayout     String // Board.layout 값 ("dj-queue" 등)
  grantedRole     String // "owner" | "editor"
  createdAt       DateTime @default(now())

  classroomRole ClassroomRoleDef @relation(fields: [classroomRoleId], references: [id], onDelete: Cascade)

  @@unique([classroomRoleId, boardLayout])
  @@index([boardLayout])
}

model ClassroomRoleAssignment {
  id              String   @id @default(cuid())
  classroomId     String
  studentId       String
  classroomRoleId String
  assignedById    String
  assignedAt      DateTime @default(now())

  classroom     Classroom        @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student       Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classroomRole ClassroomRoleDef @relation(fields: [classroomRoleId], references: [id], onDelete: Restrict)
  assignedBy    User             @relation("ClassroomRoleAssignedBy", fields: [assignedById], references: [id])

  @@unique([classroomId, studentId, classroomRoleId])
  @@index([classroomId, classroomRoleId])
  @@index([studentId])
}

// ───── Classroom Bank (2026-04-19) ─────────────────────────────────────
// 학급 화폐 + 체크카드 + 한달만기 적금 + 매점 결제. 모든 mutation은
// StudentAccount.balance + Transaction 원장에 기록. Transaction.balanceAfter
// 필드로 감사 추적 (역순 재계산 가능).

model ClassroomCurrency {
  classroomId         String   @id
  unitLabel           String   @default("원")
  monthlyInterestRate Float? // 교사 입력. null = 적금 상품 비활성
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
}

model StudentAccount {
  id          String   @id @default(cuid())
  classroomId String // 비정규화 (JOIN 회피)
  studentId   String   @unique // 1학생 1통장
  balance     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student       Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classroom     Classroom      @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  cards         StudentCard[]
  transactions  Transaction[]
  fixedDeposits FixedDeposit[]

  @@index([classroomId])
}

model StudentCard {
  id         String   @id @default(cuid())
  accountId  String   @unique // MVP: 1 account = 1 card
  cardNumber String   @unique // 표시용 "5501-1234"
  qrSecret   String // HMAC secret for token rotation (per-card, AUTH_SECRET과 섞임)
  status     String   @default("active") // active | frozen | revoked
  issuedAt   DateTime @default(now())

  account StudentAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model StoreItem {
  id          String   @id @default(cuid())
  classroomId String
  name        String
  price       Int
  stock       Int? // null = 무제한
  imageUrl    String?
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  classroom    Classroom     @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([classroomId, archived])
}

model FixedDeposit {
  id           String    @id @default(cuid())
  accountId    String
  principal    Int
  monthlyRate  Float // 가입 시점 snapshot
  startDate    DateTime  @default(now())
  maturityDate DateTime
  status       String    @default("active") // active | matured | early_withdrawn
  maturedAt    DateTime?
  openedById   String
  openedByKind String // "teacher" | "banker"

  account      StudentAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([accountId, status])
  @@index([maturityDate, status]) // cron 만기 스캔
}

// 거래 원장.
//   type: deposit | withdraw | purchase | refund | fd_open | fd_matured | fd_cancelled
//   amount: 항상 양수, 방향은 type으로 결정
//   balanceAfter: 거래 직후 잔액 (감사 추적 — Transaction 역순 누적으로 검증 가능)
model Transaction {
  id              String   @id @default(cuid())
  accountId       String
  type            String
  amount          Int
  balanceAfter    Int
  note            String?
  storeItemId     String?
  fixedDepositId  String?
  performedById   String
  performedByKind String // "teacher" | "banker" | "store-clerk" | "system"
  createdAt       DateTime @default(now())

  account      StudentAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  storeItem    StoreItem?     @relation(fields: [storeItemId], references: [id], onDelete: SetNull)
  fixedDeposit FixedDeposit?  @relation(fields: [fixedDepositId], references: [id], onDelete: SetNull)

  @@index([accountId, createdAt])
  @@index([fixedDepositId])
}

model ClassroomRolePermission {
  id          String  @id @default(cuid())
  classroomId String
  roleKey     String // "banker" | "store-clerk" | ...
  permission  String // PERMISSION_CATALOG key
  granted     Boolean @default(true)

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@unique([classroomId, roleKey, permission])
  @@index([classroomId, roleKey])
}

// ──────────────────────────────────────────────────────────────────────────
// Vibe-arcade (Seed 13) — 학급 Steam. Board(layout="vibe-arcade") 전용.
// enabled는 런칭 플래그 역할(FeatureFlag 테이블 신설 대신 Config에 흡수).
// ──────────────────────────────────────────────────────────────────────────

model VibeArcadeConfig {
  boardId                 String   @id
  enabled                 Boolean  @default(false) // 보드별 런칭 게이트
  // "teacher_approval_required"(v1 기본) | "auto_publish" | "hybrid_trusted"(v1.5)
  moderationPolicy        String   @default("teacher_approval_required")
  // 학생 1인 일일 Sonnet 토큰 상한(IN+OUT). null = 학급 풀 공유만.
  perStudentDailyTokenCap Int?     @default(45000)
  // 학급 전체 일일 토큰 풀. 0 = vibe-arcade 비활성(긴급 정지).
  classroomDailyTokenPool Int      @default(1500000)
  // U-4 학급 간 공유 (반 내부만 v1 기본)
  crossClassroomVisible   Boolean  @default(false)
  // U-2 "named" | "anonymous" | "hidden_to_peer"
  reviewAuthorDisplay     String   @default("named")
  // U-3 "stars_1_5" | "thumbs" | "emoji_5"(v2)
  reviewRatingSystem      String   @default("stars_1_5")
  // F-4 v1은 false 고정
  allowRemix              Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
}

model VibeProject {
  id               String    @id @default(cuid())
  boardId          String
  classroomId      String    // 비정규화 — 학급 스코프 빠른 스캔
  authorStudentId  String
  title            String
  description      String    @default("") // ≤500자
  // Vibe studio 3-tab split (2026-04-21). htmlContent는 <body> 본문만 보관하고
  // cssContent/jsContent는 각각 <style>/<script>로 합성된다. 기존 단일-HTML 레코드는
  // cssContent="", jsContent=""로 backfill 되며 렌더러가 그대로 동작 (body만 주입).
  htmlContent      String    // <body> 본문 — CSP sandbox 헤더 부착
  cssContent       String    @default("")
  jsContent        String    @default("")
  thumbnailUrl     String?   // 서버 Playwright headless 160×120 WebP
  // 고정 태그 5종 중 1개: "게임"|"퀴즈"|"시뮬"|"아트"|"기타" (JSON 배열)
  tags             String    @default("[]")
  // "draft"|"pending_review"|"approved"|"rejected"|"flagged"|"hidden"
  moderationStatus String    @default("draft")
  moderationNote   String?   // ≤300자
  approvedAt       DateTime?
  approvedById     String?   // Teacher User.id
  rejectedAt       DateTime?
  rejectedById     String?
  playCount        Int       @default(0)
  uniquePlayCount  Int       @default(0)
  reviewCount      Int       @default(0)
  ratingAvg        Float?
  version          Int       @default(1) // 재제출 시 증가
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  board        Board             @relation(fields: [boardId], references: [id], onDelete: Cascade)
  author       Student           @relation("VibeProjectAuthor", fields: [authorStudentId], references: [id], onDelete: Restrict)
  sessions     VibeSession[]
  reviews      VibeReview[]
  playSessions VibePlaySession[]

  @@index([boardId, moderationStatus])
  @@index([classroomId, moderationStatus, createdAt])
  @@index([authorStudentId])
}

model VibeSession {
  id           String    @id @default(cuid())
  projectId    String?   // null = 아직 프로젝트 저장 전
  // nullable — 7일 미활성 익명화 cron이 studentId=null 로 전환 (AC-G5).
  studentId    String?
  classroomId  String    // 비정규화 (쿼터 스캔). Student 익명화 후에도 유지.
  messages     Json      // [{role, content, createdAt}]
  tokensIn     Int       @default(0)
  tokensOut   Int       @default(0)
  // "active"|"completed"|"abandoned"|"failed"
  status       String    @default("active")
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  refusalCount Int       @default(0) // Anthropic stop_reason="refusal"

  project VibeProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  student Student?     @relation("VibeSessionAuthor", fields: [studentId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([studentId, startedAt])
  @@index([classroomId, startedAt])
}

model VibeReview {
  id                String   @id @default(cuid())
  projectId         String
  reviewerStudentId String
  // 1-5 별점. reviewRatingSystem="thumbs"면 1 또는 5만 허용.
  rating            Int
  comment           String   @default("")
  // "visible"|"hidden_by_teacher"|"flagged"
  moderationStatus  String   @default("visible")
  flagCount         Int      @default(0) // 임계 3 → 자동 hidden
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project  VibeProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewer Student     @relation("VibeReviewer", fields: [reviewerStudentId], references: [id], onDelete: Cascade)

  @@unique([projectId, reviewerStudentId]) // 학생 1인 1리뷰
  @@index([projectId])
  @@index([reviewerStudentId])
}

model VibePlaySession {
  id            String    @id @default(cuid())
  projectId     String
  studentId     String
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  completed     Boolean   @default(false) // iframe postMessage "완료" 수신
  reportedScore Int?      // 통계·랭킹 참고용 (게임 로직 신뢰 X)

  project VibeProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  student Student     @relation("VibePlayer", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([projectId, startedAt])
  @@index([studentId, startedAt])
}

model VibeQuotaLedger {
  id            String   @id @default(cuid())
  classroomId   String
  // Non-null + 센티넬 "__CLASSROOM__" — Postgres의 UNIQUE NULL-distinct 동작으로
  // compound unique가 깨지는 문제를 피한다. 값 관리는 `lib/vibe-arcade/quota-ledger.ts`.
  studentId     String
  date          DateTime // 자정 기준 날짜 (KST)
  tokensIn      Int      @default(0)
  tokensOut     Int      @default(0)
  sessionsCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([classroomId, studentId, date])
  @@index([classroomId, date])
  @@index([studentId, date])
}

// ── DJ Board 재생 이벤트 로그 (2026-04-22 dj-recap) ────────────────────
// Card.queueStatus='played' 전환 시 1건 기록. Card 삭제돼도 이벤트는 남아서
// 월말 리캡 집계가 안정적. 같은 곡을 재복귀 후 다시 재생하면 이벤트 2건.
model DjPlayEvent {
  id            String   @id @default(cuid())
  boardId       String
  classroomId   String
  cardId        String?  // 카드 삭제 대응 — nullable + 수동 FK 없이 ID만 보존
  title         String
  linkUrl       String?
  linkImage     String?
  videoId       String?  // youtube 11자 id — 같은 곡 집계 join key
  submitterName String?
  submitterId   String?  // Student.id 또는 User.id (교사 신청 대응)
  submitterKind String?  // "student" | "teacher" | "anon"
  durationSec   Int?     // YouTube oEmbed 에서 뽑힌 길이(초), 없으면 null
  playedAt      DateTime @default(now())

  board     Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@index([boardId, playedAt])
  @@index([classroomId, playedAt])
  @@index([videoId])
}
