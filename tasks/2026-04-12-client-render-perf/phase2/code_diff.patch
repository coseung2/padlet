From eb8a586f294cf70f9f2a227048adc5ef84c1aca6 Mon Sep 17 00:00:00 2001
From: coseung2 <coseung2@users.noreply.github.com>
Date: Sun, 12 Apr 2026 10:52:40 +0900
Subject: [PATCH 3/6] fix: memoize ColumnsBoard card grouping + CSS-driven drag
 state (client-render-perf)

- Build a cardsBySection Map once per cards change via useMemo so
  the 8 render-time calls to getCardsForSection become O(1) lookups.
  Previously a 100-card / 4-section board ran 800 filter+sort ops
  on every render, which included every card move.
- Replace e.currentTarget.style.opacity = "0.5" during drag with
  classList.add("is-dragging") and a matching .column-card.is-dragging
  CSS rule, so we no longer force an inline-style recalculation on
  dragstart/dragend.

Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>
---
 src/components/ColumnsBoard.tsx | 27 ++++++++++++++++++++-------
 src/styles/boards.css           |  7 +++++++
 2 files changed, 27 insertions(+), 7 deletions(-)

diff --git a/src/components/ColumnsBoard.tsx b/src/components/ColumnsBoard.tsx
index de0e72e..a58b343 100644
--- a/src/components/ColumnsBoard.tsx
+++ b/src/components/ColumnsBoard.tsx
@@ -1,6 +1,6 @@
 "use client";
 
-import { useState } from "react";
+import { useMemo, useState } from "react";
 import { AddCardButton } from "./AddCardButton";
 import { AddCardModal, type AddCardData } from "./AddCardModal";
 import { CardAttachments } from "./CardAttachments";
@@ -126,10 +126,23 @@ export function ColumnsBoard({
     setFolderSectionId(null);
   }
 
-  function getCardsForSection(sectionId: string) {
-    return cards
-      .filter((c) => c.sectionId === sectionId)
-      .sort((a, b) => a.order - b.order);
+  // Group cards by section once per cards change, then O(1) lookup per section.
+  // Render path previously filtered + sorted the whole card list 8×, turning
