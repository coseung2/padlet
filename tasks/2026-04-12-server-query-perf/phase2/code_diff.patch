From aff10473e62e9c4296c5b0c0cc117d32eeb80d50 Mon Sep 17 00:00:00 2001
From: coseung2 <coseung2@users.noreply.github.com>
Date: Sun, 12 Apr 2026 10:42:20 +0900
Subject: [PATCH 2/5] fix: add missing perf indexes on Account/Session/Card
 (server-query-perf)

NextAuth session validation and account lookups ran without an index
on userId, forcing sequential scans on every authenticated request.
Card.authorId was also unindexed.

Adds:
- Account(userId)
- Session(userId)
- Card(authorId)

Migration SQL is idempotent (IF NOT EXISTS) so it can be applied to
the live Supabase database via prisma db push or manual execution.

Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>
---
 .../20260412_add_perf_indexes/migration.sql           | 11 +++++++++++
 prisma/schema.prisma                                  |  4 ++++
 2 files changed, 15 insertions(+)
 create mode 100644 prisma/migrations/20260412_add_perf_indexes/migration.sql

diff --git a/prisma/migrations/20260412_add_perf_indexes/migration.sql b/prisma/migrations/20260412_add_perf_indexes/migration.sql
new file mode 100644
index 0000000..62cea99
--- /dev/null
+++ b/prisma/migrations/20260412_add_perf_indexes/migration.sql
@@ -0,0 +1,11 @@
+-- Add missing indexes on frequently-queried foreign key columns.
+-- Diagnosed in tasks/2026-04-12-server-query-perf/phase1/diagnosis.md §3-4
+
+-- NextAuth session/account lookups happen on every authenticated request.
+-- Without these indexes PostgreSQL falls back to sequential scans once the
+-- user base grows beyond a few rows.
+CREATE INDEX IF NOT EXISTS "Account_userId_idx" ON "Account"("userId");
+CREATE INDEX IF NOT EXISTS "Session_userId_idx" ON "Session"("userId");
+
+-- Card.authorId is used for author-scoped filtering (e.g. "cards I wrote").
+CREATE INDEX IF NOT EXISTS "Card_authorId_idx" ON "Card"("authorId");
diff --git a/prisma/schema.prisma b/prisma/schema.prisma
index 632a195..5353479 100644
--- a/prisma/schema.prisma
+++ b/prisma/schema.prisma
@@ -48,6 +48,7 @@ model Account {
   user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
   @@unique([provider, providerAccountId])
+  @@index([userId])
 }
 
 model Session {
@@ -57,6 +58,8 @@ model Session {
   expires      DateTime
 
   user User @relation(fields: [userId], references: [id], onDelete: Cascade)
+
+  @@index([userId])
 }
 
 // ──── Classroom system ────
@@ -170,6 +173,7 @@ model Card {
 
   @@index([boardId])
   @@index([sectionId])
+  @@index([authorId])
 }
 
 model Submission {
